#include <stdio.h>

int IP[8] = {1,5,2,0,3,7,4,6};
int FP[8] = {3,0,2,4,6,1,7,5};
int key[8] = {1,0,1,0,0,0,1,0};

void xor_op(int a[], int b[], int result[], int size) {
    for(int i = 0; i < size; i++)
        result[i] = a[i] ^ b[i];
}

void permute(int input[], int output[], int table[], int size) {
    for(int i = 0; i < size; i++)
        output[i] = input[table[i]];
}

int main() {
    int plaintext[8] = {1,0,0,1,1,0,1,1};
    int ip[8], fp[8], temp[8];

    permute(plaintext, ip, IP, 8);
    xor_op(ip, key, temp, 8);
    permute(temp, fp, FP, 8);

    printf("Cipher Text: ");
    for(int i = 0; i < 8; i++)
        printf("%d", fp[i]);

    printf("\n");

    return 0;
}
