#include <stdio.h>
#include <string.h>

// simple function to convert string to pseudo hash (for lab demo)
void md5(char input[]) {
    unsigned int hash = 0;

    for(int i = 0; input[i] != '\0'; i++) {
        hash = hash * 31 + input[i];
    }

    printf("MD5 Hash: %08x%08x%08x%08x\n",
           hash, hash+1, hash+2, hash+3);
}

int main() {
    char text[100];

    printf("Enter message: ");
    scanf("%s", text);

    md5(text);

    return 0;
}
