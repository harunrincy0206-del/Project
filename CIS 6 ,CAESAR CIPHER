✅ 7(a) Caesar Cipher
#include <stdio.h>

int main() {
    char text[100];
    int key;

    scanf(" %[^\n]", text);
    scanf("%d", &key);

    for(int i = 0; text[i] != '\0'; i++) {
        if(text[i] >= 'a' && text[i] <= 'z')
            text[i] = (text[i] - 'a' + key) % 26 + 'a';
        else if(text[i] >= 'A' && text[i] <= 'Z')
            text[i] = (text[i] - 'A' + key) % 26 + 'A';
    }

    printf("%s\n", text);
    return 0;
}
