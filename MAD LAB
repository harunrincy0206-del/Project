🧪 3. GUI VALIDATION
Login Validation
XML
<EditText android:id="@+id/user" android:hint="Username"/>
<EditText android:id="@+id/pass" android:hint="Password"/>
<Button android:id="@+id/login" android:text="Login"/>
Java
Button b = findViewById(R.id.login);

b.setOnClickListener(v -> {
    String u = ((EditText)findViewById(R.id.user)).getText().toString();
    String p = ((EditText)findViewById(R.id.pass)).getText().toString();

    if(u.equals("admin") && p.equals("1234")){
        Toast.makeText(this,"Success",Toast.LENGTH_SHORT).show();
    } else {
        Toast.makeText(this,"Invalid",Toast.LENGTH_SHORT).show();
    }
});
