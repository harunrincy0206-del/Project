🧪 7. RELATIVE LAYOUT + WEBVIEW
(a) Calculator (Simple Add)
XML
<EditText android:id="@+id/a"/>
<EditText android:id="@+id/b"/>
<Button android:id="@+id/add" android:text="Add"/>
<TextView android:id="@+id/result"/>
Java
Button b = findViewById(R.id.add);

b.setOnClickListener(v -> {
    int a = Integer.parseInt(((EditText)findViewById(R.id.a)).getText().toString());
    int c = Integer.parseInt(((EditText)findViewById(R.id.b)).getText().toString());

    ((TextView)findViewById(R.id.result)).setText(""+(a+c));
});
